# Next.js / App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js
AUTH_SECRET=replace-with-random-string
NEXTAUTH_SECRET=replace-with-random-string
# 本番（Vercel）ではデプロイ先 URL を設定（例: https://owe-manager-ver2.vercel.app）
NEXTAUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/owemanager

# Neon 等のクラウド DB では true（Vercel 本番で必須）
# DRIZZLE_SSL=true
